{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "enclave",
  "version": "0.1.0",
  "identifier": "com.enclave.app",
  "build": {
    "frontendDist": "../apps/desktop/build",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "cd apps/desktop && npm run dev",
    "beforeBuildCommand": "cd apps/desktop && npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Enclave",
        "width": 1200,
        "height": 800,
        "minWidth": 680,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data:; connect-src 'self' http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "",
    "category": "Utility",
    "shortDescription": "Secure, local-first note-taking",
    "longDescription": "Enclave is a secure, local-first, zero-knowledge note-taking application with P2P sync over local Wi-Fi. No cloud infrastructure required.",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
